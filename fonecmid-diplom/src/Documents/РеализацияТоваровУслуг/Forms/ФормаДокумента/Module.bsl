//Команда Акт об оказании услуг
&НаКлиенте
Процедура ВКМ_АктОбАказанииУслуг(Команда)
	ТабДок = Неопределено;
	ЗаполнениеАктаОбОказанииУслуг(ТабДок);
	//покажем табличный документ на экране
	Если ТабДок = Неопределено Тогда
	Иначе
	ТабДок.Показать();
	КонецЕсли;
КонецПроцедуры 

&НаСервере
Процедура ЗаполнениеАктаОбОказанииУслуг(ТабДок)
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "ВидДоговора")
		= Перечисления.ВидыДоговоровКонтрагентов.ВКМ_АбоненскаяПлата Тогда
		ДокОбъект = РеквизитФормыВЗначение("Объект");
		ДокОбъект.ВКМ_ПечатьАктаОбОказанныхУслугах(ТабДок);
	Иначе
		ТекстСообщения = "Вид договора не абоненская плата";
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
КонецПроцедуры 
//

// Выполнил не в модуле документа так, как не могу очистить табличную часть. Товары.Очистить 
// не работает в модуле объекта и  не записывает данные в Услуги
// У меня и сдесь код не всегда отрабатывает. Сдесь тоже ТЧ не очищается и не заполняется, 
// а через какое то время все работает
// Я не понимаю почему он то работат, то не работает.
// В модуле объекта никогда не отрабатывал. Ошибок не было в отладке в переменные все добавлялось
// и удалялось, но на форме все оставалось без изменений
&НаСервере
Процедура ВКМ_ВыполнитьАвтозаполнениеНаФорме()
	//  Получаем номенклатуру из констант
	НоменклатураАбонентскаяПлата = Константы.ВКМ_НоменклатураАбонентскаяПлата.Получить();
	НоменклатураРаботыСпециалиста = Константы.ВКМ_НоменклатураРаботыСпециалиста.Получить();

	Если НоменклатураАбонентскаяПлата = ПустаяСтрока(НоменклатураАбонентскаяПлата) Или НоменклатураРаботыСпециалиста
		= ПустаяСтрока(НоменклатураРаботыСпециалиста) Тогда
		ВызватьИсключение "Для автозаполнения не заполнены константы номенклатуры.
						  |Обратитесь к администратору.";
	КонецЕсли;
	
	//  Очистка табличной части
	Объект.Товары.Очистить();
	Объект.Услуги.Очистить();
	
	//  Заполнение абонентской платой
	СуммаАбонПлаты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "ВКМ_СуммаАбоненскойПлаты");
	Если СуммаАбонПлаты > 0 Тогда
		НоваяСтрока = Объект.Услуги.Добавить();
		НоваяСтрока.Номенклатура = НоменклатураАбонентскаяПлата;
		НоваяСтрока.Количество = 1;
		НоваяСтрока.Сумма = СуммаАбонПлаты;
	КонецЕсли;
	
	 //  Заполнение работами из регистра
        // Формируем границы месяца по дате документа
	НачалоМесяца = НачалоМесяца(Объект.Дата);
	КонецМесяца = КонецМесяца(Объект.Дата);
	
	Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |	ЕСТЬNULL(ВКМ_ЗадолжностиКлиента.КоличествоЧасов, 0) КАК КоличествоРабот,
    |	ЕСТЬNULL(ВКМ_ЗадолжностиКлиента.СуммаКОплате, 0) КАК СуммаРабот
    |ИЗ
    |	РегистрНакопления.ВКМ_ЗадолжностиКлиента КАК ВКМ_ЗадолжностиКлиента
    |ГДЕ
    |	ВКМ_ЗадолжностиКлиента.Период МЕЖДУ &НачалоМесяца И &КонецМесяца
    |	И ВКМ_ЗадолжностиКлиента.Договор = &Договор";
    
      Запрос.УстановитьПараметр("Договор", Объект.Договор);
        Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца);
        Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца);
        
        Результат = Запрос.Выполнить().Выбрать();
        Если Результат.Следующий() И Результат.СуммаРабот > 0 Тогда
            НоваяСтрока = Объект.Услуги.Добавить();
            НоваяСтрока.Номенклатура = НоменклатураРаботыСпециалиста;
            НоваяСтрока.Количество = Результат.КоличествоРабот;
            // Цену можно рассчитать как Сумма / Количество, либо брать из регистра/договора
            НоваяСтрока.Цена = Результат.СуммаРабот / Результат.КоличествоРабот;
            НоваяСтрока.Сумма = Результат.СуммаРабот;
        КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
	
	ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество;
	
	РассчитатьСуммуДокумента();
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
	
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
	
КонецПроцедуры

