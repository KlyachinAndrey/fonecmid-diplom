&НаСервере
Процедура ВКМ_ПрограммноеСозданиеКомандФормы()
	//Команда заполнить
	ИмяКоманды = "ВКМ_Заполнить";
	Команда = Команды.Добавить(ИмяКоманды);
	Команда.Заголовок = "Заполнить";
	Команда.Действие  = ИмяКоманды;

	Команда.Отображение = ОтображениеКнопки.Текст;

	КнопкаФормы = Элементы.Вставить(ИмяКоманды, Тип("КнопкаФормы"), КоманднаяПанель);
	КнопкаФормы.ИмяКоманды = ИмяКоманды;
	
	//Команда Печать акта об оказанных услугах
	КомандаПечать = "ВКМ_АктОбАказанииУслуг";
	Команда = Команды.Добавить(КомандаПечать);
	Команда.Заголовок = "Акт об оказании услуг";
	Команда.Действие  = КомандаПечать;

	Команда.Отображение = ОтображениеКнопки.Текст;

	КнопкаФормы = Элементы.Вставить(КомандаПечать, Тип("КнопкаФормы"), КоманднаяПанель);
	КнопкаФормы.ИмяКоманды = КомандаПечать;

КонецПроцедуры

