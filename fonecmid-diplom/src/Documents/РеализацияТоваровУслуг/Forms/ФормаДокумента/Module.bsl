		ВКМ_ВыполнитьАвтозаполнениеНаФорме();
		// Не работает. Не могу понять, что не так. Ошибок никаких нет
		//ДокОбъект = РеквизитФормыВЗначение("Объект");
		//ДокОбъект.ВКМ_ВыполнитьАвтозаполнение();
		Элементы.Страницы.ТекущаяСтраница = Элементы.ГруппаУслуги;
		
	КонецЕсли;
КонецПроцедуры 
